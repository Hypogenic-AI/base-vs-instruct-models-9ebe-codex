{"type":"item.started","item":{"id":"item_63","type":"command_execution","command":"/bin/bash -lc \"pwd && source .venv/bin/activate && python - <<'PY'\nimport json, os, shutil, traceback\nfrom pathlib import Path\nfrom datasets import load_dataset, DatasetDict, Dataset\n\nroot=Path('datasets')\nroot.mkdir(exist_ok=True)\nrecords=[]\n\ndef preview_value(v, maxlen=300):\n    if isinstance(v, str):\n        return v[:maxlen]\n    if isinstance(v, list):\n        return v[:2]\n    if isinstance(v, dict):\n        return {k: preview_value(val, 120) for k,val in list(v.items())[:5]}\n    return v\n\ndef save_samples(name, ds_obj, out_dir):\n    samples_dir=out_dir/'samples'\n    samples_dir.mkdir(parents=True, exist_ok=True)\n    if isinstance(ds_obj, DatasetDict):\n        sample_payload={}\n        for split, ds in ds_obj.items():\n            n=min(3,len(ds))\n            sample_payload[split]=[{k: preview_value(v) for k,v in ds[i].items()} for i in range(n)]\n    else:\n        n=min(5,len(ds_obj))\n        sample_payload=[{k: preview_value(v) for k,v in ds_obj[i].items()} for i in range(n)]\n    (samples_dir/f'{name}.sample.json').write_text(json.dumps(sample_payload, indent=2, ensure_ascii=False))\n\ndef add_record(name, source, location, task, obj, notes, license_='unknown'):\n    if isinstance(obj, DatasetDict):\n        splits={s: len(ds) for s,ds in obj.items()}\n        features={s: list(ds.features.keys()) for s,ds in obj.items()}\n    else:\n        splits={'train': len(obj)}\n        features={'train': list(obj.features.keys())}\n    size=sum(p.stat().st_size for p in Path(location).rglob('*') if p.is_file()) if Path(location).exists() else 0\n    records.append({'name':name,'source':source,'location':location,'task':task,'splits':splits,'features':features,'size_bytes':size,'license':license_,'notes':notes})\n\ndef load_and_save(name, source, out_name, task, kwargs, notes, license_='unknown'):\n    out_dir=root/out_name\n    print(f'\\\\nLoading {name} -> {out_dir}')\n    try:\n        ds=load_dataset(source, **kwargs)\n        if isinstance(ds, DatasetDict):\n            obj=ds\n        else:\n            obj=ds\n        if out_dir.exists():\n            shutil.rmtree(out_dir)\n        obj.save_to_disk(str(out_dir))\n        save_samples(out_name, obj, out_dir)\n        add_record(name, source, str(out_dir), task, obj, notes, license_)\n        print('saved', name)\n    except Exception as e:\n        print('FAILED', name, type(e).__name__, e)\n        traceback.print_exc(limit=1)\n        records.append({'name':name,'source':source,'location':str(out_dir),'task':task,'splits':{},'features':{},'size_bytes':0,'license':license_,'notes':notes,'error':repr(e)})\n\nload_and_save('JUST-EVAL-INSTRUCT', 're-align/just-eval-instruct', 'just_eval_instruct', 'instruction prompt evaluation', {'split':'test'}, '1k diverse prompts used by URIAL/Unlocking Spell and follow-up analyses.', 'unknown')\nload_and_save('MT-Bench Prompts', 'HuggingFaceH4/mt_bench_prompts', 'mt_bench_prompts', 'multi-turn instruction evaluation prompts', {'split':'train'}, '80 two-turn benchmark prompts for instruction-following comparison.', 'unknown')\nload_and_save('Alpaca 52k', 'tatsu-lab/alpaca', 'alpaca_52k', 'instruction-output SFT data', {'split':'train'}, 'Classic 52k instruction-output pairs useful for teacher-forced divergence over aligned response style.', 'cc-by-nc-4.0 per original Alpaca data card')\nload_and_save('WikiText-2 Raw', 'Salesforce/wikitext', 'wikitext_2_raw', 'natural language baseline corpus', {'name':'wikitext-2-raw-v1'}, 'Small natural-text corpus for contrasting base LM text continuation contexts against instruction/chat prompts.', 'Creative Commons Attribution-ShareAlike')\n# BeaverTails 30k splits; load as DatasetDict manually.\ntry:\n    print('\\\\nLoading BeaverTails 30k safety data')\n    bt=DatasetDict({\n        'train': load_dataset('PKU-Alignment/BeaverTails', split='30k_train'),\n        'test': load_dataset('PKU-Alignment/BeaverTails', split='30k_test'),\n    })\n    out_dir=root/'beavertails_30k'\n    if out_dir.exists(): shutil.rmtree(out_dir)\n    bt.save_to_disk(str(out_dir))\n    save_samples('beavertails_30k', bt, out_dir)\n    add_record('BeaverTails 30k', 'PKU-Alignment/BeaverTails', str(out_dir), 'safety/refusal prompt-response data', bt, 'Safety-labeled prompt-response data for high-divergence refusal and unsafe-request regions.', 'unknown')\n    print('saved BeaverTails')\nexcept Exception as e:\n    print('FAILED BeaverTails', type(e).__name__, e)\n    records.append({'name':'BeaverTails 30k','source':'PKU-Alignment/BeaverTails','location':'datasets/beavertails_30k','task':'safety/refusal prompt-response data','splits':{},'features':{},'size_bytes':0,'license':'unknown','notes':'Safety-labeled data.','error':repr(e)})\nload_and_save('Chatbot Arena Conversations mirror', 'dim/lmsys_chatbot_arena_conversations', 'lmsys_chatbot_arena_33k', 'real chat comparisons and prompts', {'split':'train'}, 'Open mirror of 33k Chatbot Arena conversations; used as an accessible substitute because lmsys/lmsys-chat-1m is gated.', 'cc / mirrored card')\nPath('datasets/dataset_summary.json').write_text(json.dumps(records, indent=2, ensure_ascii=False))\nprint('\\\\nSUMMARY')\nfor r in records:\n    print(r['name'], r.get('splits'), r.get('size_bytes'), r.get('error',''))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
