{"type":"item.completed","item":{"id":"item_61","type":"agent_message","text":"The residuals are not just assistant-style boilerplate. The largest positive misses are unexpectedly concentrated in WikiText narrative passages, while large negative misses often appear at `Assistant:` boundaries where the predictor expected a bigger shift than the models actually had. I’m running a few targeted summaries to quantify that before writing the report."}}
{"type":"item.started","item":{"id":"item_62","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate && python - <<'PY'\nimport pandas as pd, json, numpy as np\nfrom pathlib import Path\n\ndf = pd.read_csv('results/token_kl_metrics.csv.gz')\npred = pd.read_csv('results/heldout_predictions.csv')\nprint('rows', len(df), 'examples', df.example_id.nunique())\nprint('\\\\nBy source/segment:')\nseg = df.groupby(['source','segment']).agg(tokens=('fwd_kl','size'), mean_kl=('fwd_kl','mean'), median_kl=('fwd_kl','median'), p95_kl=('fwd_kl', lambda x: x.quantile(.95)), top1_disagree=('top1_agree', lambda x: 1-x.mean())).reset_index()\nprint(seg.to_string(index=False))\nprint('\\\\nGeneration start rows:')\nprint(df[df.is_generation_start==1].groupby('source').agg(n=('fwd_kl','size'), mean_kl=('fwd_kl','mean'), median_kl=('fwd_kl','median'), p90_kl=('fwd_kl', lambda x: x.quantile(.9))).reset_index().to_string(index=False))\nprint('\\\\nTop high residual examples:')\nhi = pred.nlargest(150, 'abs_residual_pred_rich')\nprint(hi.groupby(['example_id','source']).size().sort_values(ascending=False).head(15).to_string())\nprint('\\\\nResidual quantiles by source:')\nprint(pred.groupby('source')['abs_residual_pred_rich'].quantile([.5,.9,.98,.99]).unstack().to_string())\nprint('\\\\nKL quantiles by source:')\nprint(df.groupby('source')['fwd_kl'].quantile([.5,.9,.98,.99]).unstack().to_string())\nprint('\\\\nTop residual context classes source x class:')\nprint(hi.groupby(['source','token_class']).size().sort_values(ascending=False).head(20).to_string())\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
